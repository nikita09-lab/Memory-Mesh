# render.yaml — Infrastructure as Code for Render.com
# Docs: https://render.com/docs/blueprint-spec
#
# Deploy steps:
#   1. Push this file to your repo root
#   2. Go to render.com → New → Blueprint
#   3. Connect your GitHub repo
#   4. Fill in the env var values marked FILL_IN below
#   5. Click Apply

services:
  # ── Backend (Web Service) ──────────────────────────────────────────────────
  - type: web
    name: memorymesh-backend
    runtime: docker
    dockerfilePath: ./backend/backend.Dockerfile
    dockerContext: ./backend
    plan: starter          # $7/month — change to free for testing (cold starts)
    healthCheckPath: /health
    disk:
      name: memorymesh-data
      mountPath: /data
      sizeGB: 1            # SQLite persistent storage
    envVars:
      - key: ENV
        value: production
      - key: SECRET_KEY
        generateValue: true   # Render auto-generates a secure random value
      - key: ALGORITHM
        value: HS256
      - key: ACCESS_TOKEN_EXPIRE_MINUTES
        value: "60"
      - key: DB_PATH
        value: /data/audit.db
      - key: GROQ_API_KEY
        sync: false            # You enter this manually in Render dashboard — FILL_IN
      - key: ADMIN_PASSWORD
        sync: false            # You enter this manually — FILL_IN (strong password)
      - key: CORS_ORIGINS
        fromService:
          name: memorymesh-frontend
          type: web
          property: host
          prepend: "https://"

  # ── Frontend (Static Site — free on Render) ────────────────────────────────
  - type: web
    name: memorymesh-frontend
    runtime: docker
    dockerfilePath: ./frontend/frontend.Dockerfile
    dockerContext: ./frontend
    plan: starter
    buildCommand: ""           # handled inside Dockerfile
    envVars:
      - key: VITE_API_URL
        fromService:
          name: memorymesh-backend
          type: web
          property: host
          prepend: "https://"